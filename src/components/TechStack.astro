---
import type { Dict } from "../i18n/types";
import { sectionId } from "../utils/paths";

interface Props {
  dict: Dict;
}

const { dict } = Astro.props;
const { stack } = dict;
---

<section id={sectionId(dict.lang, "stack")}>
  <div class="container">
    <div class="section-header">
      <h2>{stack.title}</h2>
      <p>{stack.lead}</p>
    </div>
    <div class="tech-list">
      {stack.items.map((item) => <span class="tech-pill">{item}</span>)}
    </div>
  </div>
</section>
