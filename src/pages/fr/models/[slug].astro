---
import ModelPage from "../../../components/ModelPage.astro";
import { getAllModelSlugs, getModelPage } from "../../../data/model-pages";
import { getDict } from "../../../i18n";
import BaseLayout from "../../../layouts/BaseLayout.astro";

export function getStaticPaths() {
  return getAllModelSlugs().map((slug) => ({ params: { slug } }));
}

const { slug } = Astro.params;
const dict = getDict("fr");
const page = getModelPage("fr", slug!);

if (!page) {
  return Astro.redirect("/fr/");
}
---

<BaseLayout
  lang="fr"
  title={`${page.title} | Portfolio`}
  description={page.lead}
>
  <ModelPage dict={dict} page={page} />
</BaseLayout>
